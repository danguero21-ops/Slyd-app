{
  "name": "Message",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "description": "ID of the conversation"
    },
    "sender_email": {
      "type": "string",
      "description": "Email of message sender"
    },
    "content": {
      "type": "string",
      "description": "Message text content"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image attachment URL"
    },
    "is_read": {
      "type": "boolean",
      "default": false,
      "description": "Whether message has been read"
    },
    "message_type": {
      "type": "string",
      "enum": [
        "text",
        "image",
        "system"
      ],
      "default": "text"
    }
  },
  "required": [
    "conversation_id",
    "sender_email",
    "content"
  ]
}